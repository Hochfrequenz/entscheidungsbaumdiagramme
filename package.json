{
  "name": "ebd.hochfrequenz.de",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.19 <21"
  },
  "scripts": {
    "start": "vite dev --open",
    "dev": "vite dev",
    "build": "node src/lib/data/retired-ebds.js && vite build",
    "serve": "vite build && npx http-server ./build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier '**/*.{svelte,js,jsx,ts,tsx,html,css,scss,json,yml,md}' --write",
    "format:check": "prettier '**/*.{svelte,js,jsx,ts,tsx,html,css,scss,json,yml,md}' --check",
    "lint": "eslint 'src/**/*.{js,ts,svelte}' --fix",
    "lint:check": "eslint 'src/**/*.{js,ts,svelte}'"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.59.4",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-svelte": "^3.17.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "sass": "^1.100.0",
    "scss": "^0.2.4",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.1"
  },
  "type": "module",
  "dependencies": {
    "@auth0/auth0-spa-js": "^2.21.1",
    "@hochfrequenz/efoli": "^0.0.8"
  }
}
